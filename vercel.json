{
    "version": 2,
    "functions": {
        "public/index.php": { "runtime": "vercel-php@0.6.0" }
    },
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/public/index.php"
        }
    ],
    "env": {
        "APP_NAME": "Band Manager",
        "APP_ENV": "production",
        "APP_DEBUG": "false",
        "APP_URL": "asd",
        "DB_CONNECTION": "mysql",
        "DB_HOST": "aws.connect.psdb.cloud",
        "DB_PORT": "3306",
        "DB_DATABASE": "band-manager",
        "MYSQL_ATTR_SSL_CA": "/etc/pki/tls/certs/ca-bundle.crt",

        "BROADCAST_DRIVER": "log",
        "CACHE_DRIVER": "file",
        "FILESYSTEM_DISK": "local",
        "QUEUE_CONNECTON": "sync",
        "SESSION_DRIVER": "database",
        "SESSION_LIFETIME": "120"
    }
}
